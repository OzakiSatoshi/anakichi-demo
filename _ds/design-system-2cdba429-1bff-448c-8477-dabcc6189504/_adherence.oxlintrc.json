{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/notes/**",
              "components/paper/**",
              "ui_kits/techo/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Klee One|Zen Kaku Gothic New))/i]",
        "message": "Font not provided by the design system. Available: Klee One, Zen Kaku Gothic New."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|children|key|ref|className|style|children)$/]",
        "message": "<CategoryTab> doesn't accept that prop. Declared props: as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='HatchEvent'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|children|key|ref|className|style|children)$/]",
        "message": "<HatchEvent> doesn't accept that prop. Declared props: as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Note'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|rotate|lift|as|children|key|ref|className|style|children)$/]",
        "message": "<Note> doesn't accept that prop. Declared props: color, rotate, lift, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|children|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='RingPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|children|key|ref|className|style|children)$/]",
        "message": "<RingPanel> doesn't accept that prop. Declared props: as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimeRailRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:hour|band|bracket|children|key|ref|className|style|children)$/]",
        "message": "<TimeRailRow> doesn't accept that prop. Declared props: hour, band, bracket, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ZebraList'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|key|ref|className|style|children)$/]",
        "message": "<ZebraList> doesn't accept that prop. Declared props: items."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "CategoryTab": {
        "replaces": []
      },
      "HatchEvent": {
        "replaces": []
      },
      "Note": {
